# ==============================================================================
# 非天然氨基酸文献获取
# 入口：python3 nnaa_fetch.py run
# ==============================================================================

paths:
  master_csv: /share/allpdfs/final_both_doi_filename_mapping_8.14.csv
  master_doi_column: DOI
  master_metadata_csv: /share/allpdfs/doi_metadata_crossref.csv
  extra_doi_csvs: []
  output_dir: /root/非天然氨基酸/output
  state_dir: /root/非天然氨基酸/state
  log_dir: /root/非天然氨基酸/logs

search:
  date_range_mode: explicit
  date_from: "2024-01-01"
  date_to: "2026-06-25"

pubmed:
  enabled: true
  email: "your_email@example.com"
  use_keywords_from_code: true
  batch_size: 500
  efetch_batch_size: 200
  max_pmids: 0

crossref:
  enabled: true
  mailto: "your_email@example.com"
  query_param: bibliographic
  limit_per_query: 300
  rows_per_query: 200
  request_interval_sec: 1.0
  filter_types:
    - "journal-article"
  pathway:
    query_source: nnaa_strategy
    nnaa_strategy:
      max_queries: 200
  enzymatic:
    query_source: nnaa_strategy
    nnaa_strategy:
      max_queries: 200
  fermentation:
    query_source: nnaa_strategy
    nnaa_strategy:
      max_queries: 200
  chemical:
    query_source: nnaa_strategy
    nnaa_strategy:
      max_queries: 300
  hybrid:
    query_source: nnaa_strategy
    nnaa_strategy:
      max_queries: 150

article_type_filter:
  enabled: true
  exclude_publication_type_patterns:
    - "review"
    - "systematic review"
    - "meta-analysis"
    - "editorial"
    - "published erratum"
    - "retraction of publication"

literature_cleaner:
  enabled: true

deduplication:
  use_master_csv: false
  normalize_doi: true
  strip_doi_prefix: true
  skip_invalid_doi: true
  dedupe_by_title: true
  dedupe_by_title_and_pub_date: true
  include_previous_outputs: true
  previous_output_glob: "nnaa_dois_*.csv"
  previous_output_doi_column: doi

local_pdf:
  enabled: true

title_filter:
  enabled: false

ai_screening:
  enabled: false
  api_base: "https://api.openai.com/v1"
  api_key_env: "NNAA_FETCH_OPENAI_API_KEY"
  api_key: ""
  model: "gpt-4o-mini"
  batch_size: 12
  request_interval_sec: 0.5
  checkpoint_enabled: true
  only_keep_passed: false
  keep_on_batch_error: true
  fail_if_missing_key: false
  extra_instructions: |
    非天然氨基酸（NNAA）。nnaa_category：pathway=代谢通路；enzymatic=酶法；fermentation=发酵；chemical=化学合成；hybrid=酶化学联用。

    【核心判定原则】pass_filter=true 的文章必须满足：
      文章的核心贡献是报告一种或多种 NNAA 的"合成/制备/生产方法"，
      包括：化学合成路线、酶法/生物催化制备、发酵工艺、代谢工程通路、生物合成基因簇功能解析、或上述方法的组合。

    【可通过 pass_filter=true 的情形】
      ① 明确报告合成路线/工艺参数（收率、e.e.、产量、滴度等）的 NNAA 制备论文
      ② 代谢工程：报告改造微生物菌株使其合成特定 NNAA，含完整的代谢通路设计
      ③ 生物合成基因簇：鉴定并阐明 NNAA 生物合成通路（即使应用场景为天然产物）
      ④ 酶催化：报告酶对底物→NNAA 的转化，含具体酶学参数和转化率
      ⑤ 含通用术语 "non-natural amino acid"/"unnatural amino acid"/"ncAA" 且明确描述合成方法学

    【必须排除 pass_filter=false 的情形】
      ① 目标化合物是20种标准氨基酸（Ala/Arg/Asn/Asp/Cys/Gln/Glu/Gly/His/Ile/Leu/Lys/Met/Phe/
         Pro/Ser/Thr/Trp/Tyr/Val）的合成：即使方法新颖，只要产物是标准氨基酸也须排除
      ② 疾病/医学研究：NNAA 仅作为生物标志物、病理机制组分或药物靶点，未报告其制备方案
      ③ 纯应用研究：仅使用市售/预制 NNAA 进行蛋白标记、点击化学、生物正交反应，不含制备步骤
      ④ 酶抑制/机制研究：以 NNAA 作为抑制剂/探针，研究酶的机制，但不描述该 NNAA 的合成方法
      ⑤ 终产物非氨基酸：以 NNAA 作为原料底物，但反应目标产物不是氨基酸类化合物
      ⑥ 综述/应用综述：仅回顾 NNAA 的应用（蛋白工程、化学生物学），不包含合成方法学主体内容
      ⑦ 植物/微生物天然抗性机制：NNAA 合成仅作为生物防御功能的研究对象，且文章核心是功能而非制备

output:
  run_dir_pattern: "%Y-%m-%d"
  track_filenames:
    pathway: pathway.csv
    enzymatic: synthesis_enzymatic.csv
    fermentation: synthesis_fermentation.csv
    chemical: synthesis_chemical.csv
    hybrid: synthesis_hybrid.csv
  save_combined_in_run_dir: true
  combined_filename: all.csv
  save_legacy_flat_file: true
  filename_pattern: "nnaa_dois_%Y-%m_%H%M%S.csv"
  columns:
    - doi
    - title
    - source
    - nnaa_track
    - pmid
    - journal
    - pub_date
    - publication_types
    - abstract
    - local_has_pdf
    - nnaa_compound
    - ai_article_type
    - lit_type_zh
    - ai_domain_relevant
    - ai_has_experiment
    - ai_pass
    - ai_rationale_zh
    - ai_nnaa_category
    - ai_synthesis_method
    - ai_has_pathway_or_synthesis
    - ai_compound
    - fetched_at
  save_empty_result: false
